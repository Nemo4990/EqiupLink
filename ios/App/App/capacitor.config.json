{
	"appId": "com.equiplink.app",
	"appName": "EquipLink",
	"webDir": "dist",
	"server": {
		"androidScheme": "https",
		"iosScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"backgroundColor": "#030712",
			"androidSplashResourceName": "splash",
			"androidScaleType": "CENTER_CROP",
			"showSpinner": false,
			"splashFullScreen": true,
			"splashImmersive": true
		}
	},
	"packageClassList": [
		"AppPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
